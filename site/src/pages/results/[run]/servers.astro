---
import Run from '../../../layouts/Run.astro';
import runs from '../../../data/runs.json';
import type { RunExport } from '../../../../scripts/lib/loader.ts';

export async function getStaticPaths() {
  return runs.map(r => ({ params: { run: r.id } }));
}

const { run } = Astro.params;
const data: RunExport = (await import(`../../../data/${run}.json`)).default;
---

<Run title={`${run} — Servers`} run={run} date={data.date} activeSection="servers">
  <div class="placeholder">
    <div class="placeholder-icon">🖥</div>
    <h2 class="placeholder-title">Servers</h2>
    <p class="placeholder-sub">
      Per-server breakdown — latency percentiles, memory usage, data volume, and test-by-test results for each of the {data.servers.length} servers in this run.
    </p>
    <p class="placeholder-badge">Coming soon</p>
  </div>
</Run>

