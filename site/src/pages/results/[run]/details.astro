---
import Run from '../../../layouts/Run.astro';
import EChart from '../../../components/EChart.svelte';
import Matrix from '../../../components/Matrix.astro';
import Widget from '../../../components/Widget.astro';
import runs from '../../../data/runs.json';
import type { RunExport } from '../../../types';
import { fmtMs, fmtBytes, latencyColor } from '../../../utils';
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

export async function getStaticPaths() {
  return runs.map(r => ({ params: { run: r.id } }));
}

const { run } = Astro.params;
const hasErrors = existsSync(resolve(`src/data/${run}.errors.csv`));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const data: RunExport = (await import(`../../../data/${run}.json`)).default;
const { servers, config } = data;
const tests = config.tests;
const topVu = String(Math.max(...config.vus));

function preflightStatus(s: typeof servers[0], t: string) {
  return s.preflight[t] ?? 'skip';
}

function getP95(s: typeof servers[0], t: string): number | null {
  const bm = s.benchmark?.[t]?.[topVu];
  return bm ? bm.p95 : null;
}

const xAxis = {
  type: 'category',
  data: servers.map(s => s.id),
  axisLine: { lineStyle: { color: '#2a2b3d' } },
  axisTick: { show: false },
  axisLabel: { color: '#9a9ab0', interval: 0, overflow: 'truncate', width: 80 },
};

const yAxis = { type: 'value', show: false };

const barSeries = (color: string, field: 'memBytes' | 'peakMemBytes' | 'dataBytes', name?: string, opts: Record<string, unknown> = {}) => ({
  type: 'bar',
  name,
  barMaxWidth: 40,
  barGap: '-100%',
  itemStyle: { color, borderRadius: [2, 2, 0, 0] },
  label: { show: true, position: 'top', color: '#9a9ab0' },
  data: servers.map(s => {
    const v = s.snapshot?.[field] ?? null;
    return { value: v ?? 0, label: v ? { formatter: fmtBytes(v) } : { show: false } };
  }),
  ...opts,
});

const tooltip = { trigger: 'axis', axisPointer: { type: 'shadow' } };

const legend = {
  data: ['Peak', 'Idle'],
  bottom: 0,
  textStyle: { color: '#9a9ab0' },
  itemWidth: 12,
  itemHeight: 10,
};

const baseOption = {
  backgroundColor: 'transparent',
  grid: { left: 8, right: 8, top: 8, bottom: 64, containLabel: false },
  xAxis,
  yAxis,
};

// Peak renders first (behind), idle on top. barGap: '-100%' overlaps them.
// silent: true on peak prevents hover from bringing it to the front.
const memOption  = { ...baseOption, tooltip, legend, series: [barSeries('#1F4EA6', 'peakMemBytes', 'Peak', { silent: true }), barSeries('#5794F2', 'memBytes', 'Idle')] };
const diskOption = { ...baseOption, series: [barSeries('#B877D9', 'dataBytes')] };

const serverIds = servers.map(s => s.id);

const capabilityCells = servers.map(s =>
  tests.map(t => {
    const st = preflightStatus(s, t);
    return {
      content: st === 'pass' ? '✓' : st === 'fail' ? '✗' : '~',
      class: `cell-${st}`,
      title: `${s.id}/${t}: ${st}`,
    };
  })
);

const latencyCells = servers.map(s =>
  tests.map(t => {
    const p95 = getP95(s, t);
    return {
      content: fmtMs(p95),
      class: 'cell-latency',
      style: `color:${latencyColor(p95)}`,
      title: `${s.id}/${t}: ${fmtMs(p95)}`,
    };
  })
);
---

<Run title={`${run} — Breakdown`} run={run} date={data.date} activeSection="details">

  <Widget title="Capability Matrix" tip="Whether each server passed, failed, or skipped each capability check during preflight.">
    <Matrix rowLabels={serverIds} colLabels={tests} cells={capabilityCells} testIds cellWidth="55px"/>
  </Widget>

  <Widget title="p95 Latency" badge={`${topVu} VUs`} tip={`95th-percentile response time at ${topVu} virtual users.`}>
    <Matrix rowLabels={serverIds} colLabels={tests} cells={latencyCells} testIds cellWidth="55px" />
  </Widget>

  <div class="widget-row">
    <Widget title="Memory" tip="Idle memory usage (light blue, front) overlaid on peak memory during benchmarks (dark blue, back) per server.">
      <EChart client:only="svelte" option={memOption} width="100%" height="260px" />
    </Widget>
    <Widget title="Disk" tip="Idle data directory size per server.">
      <EChart client:only="svelte" option={diskOption} width="100%" height="260px" />
    </Widget>
  </div>

  {hasErrors && (
    <Widget title="Logs">
      <a class="log-link" href={`${base}/results/${run}/errors.csv`} download>errors.csv</a>
    </Widget>
  )}

</Run>

<style>
  .log-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
  }
  .log-link:hover { text-decoration: underline; }

  .widget-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .widget-row :global(.widget) { margin-bottom: 0; }
</style>
