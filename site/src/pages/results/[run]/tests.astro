---
import Run from '../../../layouts/Run.astro';
import runs from '../../../data/runs.json';
import type { RunExport } from '../../../types';

export async function getStaticPaths() {
  return runs.map(r => ({ params: { run: r.id } }));
}

const { run } = Astro.params;
const data: RunExport = (await import(`../../../data/${run}.json`)).default;
---

<Run title={`${run} — Tests`} run={run} date={data.date} activeSection="tests">
  <div class="placeholder">
    <div class="placeholder-icon">🧪</div>
    <h2 class="placeholder-title">Tests</h2>
    <p class="placeholder-sub">
      Per-test breakdown — throughput curves across VU levels, latency distributions, and server-by-server comparison for each of the {data.config.tests.length} tests in this run.
    </p>
    <p class="placeholder-badge">Coming soon</p>
  </div>
</Run>

