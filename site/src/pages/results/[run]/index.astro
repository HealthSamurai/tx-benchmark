---
import Run from '../../../layouts/Run.astro';
import ScoreTable from '../../../components/ScoreTable.astro';
import runs from '../../../data/runs.json';
import type { RunExport } from '../../../../scripts/lib/loader.ts';

export async function getStaticPaths() {
  return runs.map(r => ({ params: { run: r.id } }));
}

const { run } = Astro.params;
const data: RunExport = (await import(`../../../data/${run}.json`)).default;
---

<Run title={`${run} Results`} run={run} date={data.date} activeSection="overview">
  <header class="page-header">
    <p class="page-eyebrow">Composite Score</p>
    <h1 class="page-title">Results</h1>
    <p class="page-sub">
      {data.servers.length} servers · {data.config.tests.length} tests · {data.date}
    </p>
  </header>

  <ScoreTable servers={data.servers} tests={data.config.tests} />
</Run>

<style>
  .page-header {
    padding-top: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .page-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-2);
  }

  .page-title {
    font-size: var(--text-3xl);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .page-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
</style>
