---
import Base from './Base.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
const hasSidebar = Astro.slots.has('sidebar');
---
<Base title={`${title} — FHIR TX Benchmark`}>
  <div class={`doc-page${hasSidebar ? ' has-sidebar' : ''}`}>
    {hasSidebar && (
      <aside class="sidebar">
        <slot name="sidebar" />
      </aside>
    )}
    <article class="prose">
      <slot />
    </article>
  </div>
</Base>

<style>
  .doc-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-6) var(--space-8);
  }

  .doc-page.has-sidebar {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
  }

  @media (max-width: 800px) {
    .doc-page.has-sidebar { grid-template-columns: 1fr; }
    .sidebar { display: none; }
  }

  /* Sidebar */
  .sidebar {
    position: sticky;
    top: 72px;
    align-self: start;
    padding-top: 2px;
    font-size: var(--text-sm);
  }

  /* Nav label */
  .sidebar :global(.nav-label) {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-2);
    margin-top: var(--space-5);
    display: block;
  }

  .sidebar :global(.nav-label:first-child) {
    margin-top: 0;
  }

  /* Strip browser list defaults */
  .sidebar :global(ul),
  .sidebar :global(ol) {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar :global(li) {
    margin: 0;
    padding: 0;
  }

  /* Links */
  .sidebar :global(a) {
    color: var(--text-muted);
    text-decoration: none;
    display: block;
    padding: 4px 8px;
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .sidebar :global(a:hover) {
    color: var(--text);
    background: rgba(255,255,255,0.04);
    text-decoration: none;
  }

  .sidebar :global(a.active) {
    color: var(--text);
    background: rgba(255,255,255,0.07);
  }

  /* Prose styles */
  .prose {
    min-width: 0;
    line-height: 1.75;
  }

  .prose :global(h1) {
    font-size: var(--text-3xl);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 600;
    color: #e8e8e8;
    letter-spacing: -0.01em;
    margin-top: var(--space-7);
    margin-bottom: var(--space-4);
  }

  .prose :global(h3) {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
    color: var(--text-dim);
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1px 5px;
    color: #c9d1d9;
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    overflow-x: auto;
    margin-bottom: var(--space-5);
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: var(--space-5);
  }

  .prose :global(thead th) {
    text-align: left;
    padding: 6px 12px;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .prose :global(tbody td) {
    padding: 8px 12px;
    border-bottom: 1px solid #15161c;
    color: var(--text-dim);
    vertical-align: top;
  }

  .prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-5);
    margin-bottom: var(--space-4);
    color: var(--text-dim);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  /* KaTeX display math */
  .prose :global(.katex-display) {
    margin: var(--space-5) 0;
    overflow-x: auto;
    padding: var(--space-4) var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .prose :global(.katex-display .katex) {
    font-size: 1.1em;
  }
</style>
