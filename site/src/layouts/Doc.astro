---
import Base from './Base.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname;
const hasToc = Astro.slots.has('toc');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const DOC_LINKS = [
  { label: 'Introduction', href: `${base}/introduction` },
  { label: 'Methodology',  href: `${base}/methodology`  },
  { label: 'Data',         href: `${base}/data`          },
];
---
<Base title={`${title} — FHIR TX Benchmark`}>
  <div class="doc-layout">
    <!-- Left: doc section nav -->
    <aside class="doc-nav">
      <span class="nav-label">Docs</span>
      <nav>
        {DOC_LINKS.map(({ label, href }) => (
          <a href={href} class={`doc-link${path.startsWith(href) ? ' active' : ''}`}>
            {label}
          </a>
        ))}
      </nav>
    </aside>

    <!-- Center: prose content -->
    <article class="prose">
      <slot />
    </article>

    <!-- Right: per-page TOC (optional) -->
    {hasToc && (
      <aside class="toc">
        <slot name="toc" />
      </aside>
    )}
  </div>
</Base>

<style>
  .doc-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-6) var(--space-8);
    display: grid;
    grid-template-columns: 160px 1fr 180px;
    gap: var(--space-8);
  }

  /* When no TOC, collapse to 2-column */
  .doc-layout:not(:has(.toc)) {
    grid-template-columns: 160px 1fr;
    max-width: 960px;
  }

  @media (max-width: 900px) {
    .doc-layout { grid-template-columns: 1fr; }
    .doc-nav, .toc { display: none; }
  }

  /* Left nav */
  .doc-nav {
    position: sticky;
    top: 72px;
    align-self: start;
    padding-top: 2px;
  }

  .nav-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: block;
    margin-bottom: var(--space-3);
  }

  .doc-link {
    display: block;
    padding: 4px 8px;
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
    margin-bottom: 1px;
  }

  .doc-link:hover {
    color: var(--text);
    background: rgba(255,255,255,0.04);
    text-decoration: none;
  }

  .doc-link.active {
    color: var(--text);
    background: rgba(255,255,255,0.07);
  }

  /* Right TOC */
  .toc {
    position: sticky;
    top: 72px;
    align-self: start;
    padding-top: 2px;
    font-size: var(--text-sm);
  }

  .toc :global(.toc-label) {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: block;
    margin-bottom: var(--space-3);
  }

  .toc :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .toc :global(li) { margin: 0; padding: 0; }

  .toc :global(a) {
    color: var(--text-muted);
    text-decoration: none;
    display: block;
    padding: 3px 8px;
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .toc :global(a:hover) {
    color: var(--text);
    background: rgba(255,255,255,0.04);
  }

  /* Prose */
  .prose {
    min-width: 0;
    line-height: 1.75;
  }

  .prose :global(h1) {
    font-size: var(--text-3xl);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 600;
    color: #e8e8e8;
    letter-spacing: -0.01em;
    margin-top: var(--space-7);
    margin-bottom: var(--space-4);
  }

  .prose :global(h3) {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
    color: var(--text-dim);
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1px 5px;
    color: #c9d1d9;
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    overflow-x: auto;
    margin-bottom: var(--space-5);
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: var(--space-5);
  }

  .prose :global(thead th) {
    text-align: left;
    padding: 6px 12px;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .prose :global(tbody td) {
    padding: 8px 12px;
    border-bottom: 1px solid #15161c;
    color: var(--text-dim);
    vertical-align: top;
  }

  .prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-5);
    margin-bottom: var(--space-4);
    color: var(--text-dim);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(.katex-display) {
    margin: var(--space-5) 0;
    overflow-x: auto;
    padding: var(--space-4) var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .prose :global(.katex-display .katex) {
    font-size: 1.1em;
  }
</style>
