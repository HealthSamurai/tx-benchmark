---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
}
const { title = 'FHIR TX Benchmark' } = Astro.props;
const path = Astro.url.pathname;

const isDocsActive  = ['/introduction', '/methodology', '/data', '/servers'].some(p => path.startsWith(p));
const isRunsActive  = path.startsWith('/runs') || path.startsWith('/results');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.40/dist/katex.min.css" />
  <ViewTransitions />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="wordmark">
        <span class="wordmark-accent">FHIR</span>
        <span class="wordmark-label">TX Benchmark</span>
      </a>

      <nav class="site-nav">
        <a href="/runs"         class={`nav-link${isRunsActive  ? ' nav-link--active' : ''}`}>Runs</a>
        <a href="/introduction" class={`nav-link${isDocsActive  ? ' nav-link--active' : ''}`}>Docs</a>
        <a href="https://github.com/HealthSamurai/tx-benchmark"
           class="nav-link nav-link--icon"
           target="_blank"
           rel="noopener">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-label="GitHub">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87
              2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
              0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21
              2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04
              2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82
              2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
              0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>
</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(17, 18, 23, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .wordmark {
    display: flex;
    align-items: baseline;
    gap: 6px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .wordmark:hover { text-decoration: none; }

  .wordmark-accent {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #f28c3a;
  }

  .wordmark-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-dim);
    letter-spacing: 0.01em;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    padding: 6px 10px;
    border-radius: var(--radius);
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-link--icon {
    padding: 6px 8px;
    display: flex;
    align-items: center;
  }

  .nav-link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .nav-link--active {
    color: var(--text);
  }
</style>
