---
import Base from './Base.astro';

interface Props {
  title: string;
  run: string;
  date: string;
  servers: string[];
  testCategories: string[];
  activeSection?: string; // 'overview' | 'server:[name]' | 'test:[category]'
}

const { title, run, date, servers, testCategories, activeSection = 'overview' } = Astro.props;

const CATEGORY_LABELS: Record<string, string> = {
  LK: 'Lookup',
  VC: 'Validate code',
  EX: 'Expand',
  SS: 'Subsumes',
  CM: 'Translate',
  FS: 'FHIR search',
};
---

<Base title={`${title} — FHIR TX Benchmark`}>
  <div class="run-layout">
    <aside class="sidebar">
      <div class="run-identity">
        <span class="run-id">{run}</span>
        <span class="run-date">{date}</span>
      </div>

      <nav class="sidebar-nav">
        <a
          href={`/results/${run}`}
          class={`nav-item${activeSection === 'overview' ? ' active' : ''}`}
        >
          Overview
        </a>

        <div class="nav-section">
          <span class="nav-section-label">Servers</span>
          {servers.map(server => (
            <a
              href={`/results/${run}/server/${server}`}
              class={`nav-item nav-item--sub${activeSection === `server:${server}` ? ' active' : ''}`}
            >
              {server}
            </a>
          ))}
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Tests</span>
          {testCategories.map(cat => (
            <a
              href={`/results/${run}/test/${cat.toLowerCase()}`}
              class={`nav-item nav-item--sub${activeSection === `test:${cat}` ? ' active' : ''}`}
            >
              {CATEGORY_LABELS[cat] ?? cat}
            </a>
          ))}
        </div>
      </nav>
    </aside>

    <main class="run-main">
      <slot />
    </main>
  </div>
</Base>

<style>
  .run-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    min-height: calc(100vh - 52px);
  }

  @media (max-width: 800px) {
    .run-layout { grid-template-columns: 1fr; }
    .sidebar { display: none; }
  }

  /* Sidebar */
  .sidebar {
    border-right: 1px solid var(--border);
    padding: var(--space-6) var(--space-4);
    position: sticky;
    top: 52px;
    height: calc(100vh - 52px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .run-identity {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }

  .run-id {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    font-weight: 600;
  }

  .run-date {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-top: var(--space-4);
  }

  .nav-section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0 8px;
    margin-bottom: var(--space-1);
    display: block;
  }

  .nav-item {
    display: block;
    padding: 5px 8px;
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
    font-weight: 500;
  }

  .nav-item--sub {
    font-weight: 400;
  }

  .nav-item:hover {
    color: var(--text);
    background: rgba(255,255,255,0.04);
  }

  .nav-item.active {
    color: var(--text);
    background: rgba(255,255,255,0.07);
  }

  /* Main content */
  .run-main {
    padding: var(--space-6) var(--space-7) var(--space-8);
    min-width: 0;
    max-width: 1300px;
  }
</style>
