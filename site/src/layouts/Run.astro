---
import Base from './Base.astro';

interface Props {
  title: string;
  run: string;
  date: string;
  activeSection?: string; // 'overview' | 'servers' | 'tests' | 'details'
}

const { title, run, date, activeSection = 'overview' } = Astro.props;

const NAV = [
  { id: 'overview', label: 'Overview',  href: `/results/${run}`         },
  { id: 'servers',  label: 'Servers',   href: `/results/${run}/servers`  },
  { id: 'tests',    label: 'Tests',     href: `/results/${run}/tests`    },
  { id: 'details',  label: 'Details',   href: `/results/${run}/details`  },
];
---

<Base title={`${title} — FHIR TX Benchmark`}>
  <div class="run-layout">
    <aside class="sidebar">
      <div class="run-identity">
        <a href="/runs" class="all-runs">← All runs</a>
        <span class="run-id">{run}</span>
        <span class="run-date">{date}</span>
      </div>

      <nav class="sidebar-nav">
        {NAV.map(({ id, label, href }) => (
          <a
            href={href}
            class={`nav-item${activeSection === id ? ' active' : ''}`}
          >
            {label}
          </a>
        ))}
      </nav>
    </aside>

    <main class="run-main">
      <slot />
    </main>
  </div>
</Base>

<style>
  .run-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    min-height: calc(100vh - 52px);
  }

  @media (max-width: 800px) {
    .run-layout { grid-template-columns: 1fr; }
    .sidebar { display: none; }
  }

  /* Sidebar */
  .sidebar {
    border-right: 1px solid var(--border);
    padding: var(--space-5) var(--space-4) var(--space-6);
    position: sticky;
    top: 52px;
    height: calc(100vh - 52px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .run-identity {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }

  .all-runs {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: var(--space-1);
    transition: color 0.15s;
  }
  .all-runs:hover { color: var(--text); text-decoration: none; }

  .run-id {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .run-date {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-item {
    display: block;
    padding: 6px 10px;
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
    font-weight: 500;
  }

  .nav-item:hover {
    color: var(--text);
    background: rgba(255,255,255,0.05);
    text-decoration: none;
  }

  .nav-item.active {
    color: var(--text);
    background: rgba(255,255,255,0.08);
  }

  /* Main content */
  .run-main {
    padding: var(--space-6) var(--space-8) var(--space-8);
    min-width: 0;
  }
</style>
