---
import Base from './Base.astro';
import runs from '../data/runs.json';

interface Props {
  title: string;
  run: string;
  date: string;
  activeSection?: string;
}

const { title, run, date, activeSection = 'overview' } = Astro.props;
const runName = runs.find(r => r.id === run)?.name ?? run;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const TABS = [
  { id: 'overview',  label: 'Overview',  href: `${base}/results/${run}`         },
  { id: 'details',   label: 'Breakdown', href: `${base}/results/${run}/details`  },
  { id: 'servers',   label: 'Servers',   href: `${base}/results/${run}/servers`  },
  { id: 'tests',     label: 'Tests',     href: `${base}/results/${run}/tests`    },
];
---

<Base title={`${title} — FHIR TX Benchmark`}>
  <div class="run-main">
    <!-- Run identity header -->
    <div class="run-header">
      <a href={`${base}/runs`} class="back-link">← All runs</a>
      <h1 class="run-name">{runName}</h1>
      <p class="run-date">{date}</p>
    </div>

    <!-- Tab nav -->
    <nav class="tab-nav">
      {TABS.map(({ id, label, href }) => (
        <a href={href} class={`tab${activeSection === id ? ' active' : ''}`}>{label}</a>
      ))}
    </nav>

    <div class="run-content">
      <slot />
    </div>
  </div>
</Base>

<style>
  .run-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-8);
  }

  /* Run identity header */
  .run-header {
    margin-bottom: var(--space-6);
  }

  .back-link {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-3);
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--text); text-decoration: none; }

  .run-name {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-1);
  }

  .run-date {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* Tabs */
  .tab-nav {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-7);
  }

  .tab {
    display: flex;
    align-items: center;
    height: 40px;
    padding: 0 14px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px; /* overlap the nav border-bottom */
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .tab:hover { color: var(--text); text-decoration: none; }

  .tab.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .run-content {
    padding-top: var(--space-4);
  }
</style>
