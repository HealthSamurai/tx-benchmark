---
import { getCollection, render } from 'astro:content';
import MD from './MD.astro';

const tests = await getCollection('tests');
const byId = Object.fromEntries(tests.map(t => [t.id, t]));

const groups = [
  { label: 'FS — FHIR Search',   anchor: 'fs--fhir-search',   ids: ['FS01'] },
  { label: 'LK — Code Lookup',   anchor: 'lk--code-lookup',   ids: ['LK01','LK02','LK03','LK04','LK05'] },
  { label: 'VC — Validate Code', anchor: 'vc--validate-code', ids: ['VC01','VC02','VC03'] },
  { label: 'EX — Expand',        anchor: 'ex--expand',        ids: ['EX01','EX02','EX03','EX04','EX05','EX06','EX07','EX08'] },
  { label: 'SS — Subsumes',      anchor: 'ss--subsumes',      ids: ['SS01'] },
  { label: 'CM — Translate',     anchor: 'cm--translate',     ids: ['CM01','CM02'] },
];
---

{groups.map(({ label, anchor, ids }) => (
  <div class="test-group">
    <h2 id={anchor}>{label}</h2>
    {ids.map(async id => {
      const entry = byId[id.toLowerCase()];
      if (!entry) return null;
      const { Content } = await render(entry);
      return (
        <div class="test-entry">
          <h3 id={id.toLowerCase()}>{id} — {entry.data.title}</h3>
          <p class="test-op"><strong>Operation:</strong>{' '}<code>{entry.data.operation}</code></p>
          <p class="test-desc"><strong>Description:</strong>{' '}<MD content={entry.data.summary} /></p>
          <p class="test-preflight"><strong>Preflight:</strong>{' '}<MD content={entry.data.preflight} /></p>
          {entry.data.sample && (
            <details class="sample-details">
              <summary>Preflight request</summary>
              <div class="sample-body">
                <button class="copy-btn" onclick="navigator.clipboard.writeText(this.parentElement.querySelector('pre').textContent).then(()=>{this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',1500)})">Copy</button>
                <MD content={entry.data.sample} inline={false} />
              </div>
            </details>
          )}
          <hr />
        </div>
      );
    })}
  </div>
))}

<style>
  .test-group h2 { margin-top: 2.5rem; }
  .test-entry h3 { margin-top: 1.75rem; }
  .test-op, .test-desc, .test-preflight { margin: 0.4rem 0; }
  .test-op code { font-size: 0.875em; }
  .test-preflight { font-size: var(--text-sm); color: var(--text-muted); }
  hr { margin: 1.5rem 0; border-color: var(--border); }

  .sample-details { margin-top: 0.75rem; }
  .sample-details summary {
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--text-muted);
    user-select: none;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .sample-details summary::before {
    content: '▶';
    font-size: 0.6em;
    transition: transform 0.15s;
  }
  .sample-details[open] summary::before { transform: rotate(90deg); }
  .sample-details summary::-webkit-details-marker { display: none; }

  .sample-body {
    position: relative;
    margin-top: 0.5rem;
  }
  .sample-body :global(pre) {
    margin: 0;
    font-size: var(--text-sm);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    overflow-x: auto;
  }

  .copy-btn {
    position: absolute;
    top: 0.4rem;
    right: 0.5rem;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2px 6px;
    cursor: pointer;
    z-index: 1;
  }
  .copy-btn:hover { color: var(--text); border-color: var(--text-muted); }
</style>
