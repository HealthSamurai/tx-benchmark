---
import Run from '../layouts/Run.astro';
import ScoreTable from './ScoreTable.astro';
import Widget from './Widget.astro';
import runs from '../data/runs.json';
import type { RunExport } from '../types';

interface Props { id: string; }

const { id } = Astro.props;
const data: RunExport = (await import(`../data/${id}.json`)).default;
const name = runs.find(r => r.id === id)?.name ?? id;
---

<Run title={`${name} Results`} run={id} date={data.date} activeSection="overview">
  <Widget
    title="Composite Score"
    tip="Servers ranked by weighted throughput (wRPS) — effective requests per second adjusted so that high-RPS tests don't dominate the score. The top performer is set to 100; all others are expressed as a percentage of that."
  >
    <ScoreTable servers={data.servers} tests={data.config.tests} run={id} />
  </Widget>
</Run>
