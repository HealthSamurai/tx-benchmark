---
interface Props {
  title: string;
  badge?: string;
  tip?: string;
}

const { title, badge, tip } = Astro.props;
---

<div class="widget">
  <div class="widget-header">
    <span class="widget-title">{title}</span>
    {badge && <span class="widget-badge">{badge}</span>}
    {tip && (
      <span class="info-wrap">
        <span class="info-icon">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm0 3.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2zM7 7h2v5H7V7z"/>
          </svg>
        </span>
        <div class="info-popover">{tip}</div>
      </span>
    )}
  </div>
  <div class="widget-body">
    <slot />
  </div>
</div>
