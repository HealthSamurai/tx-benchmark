---
import type { ServerData } from '../types';
import { fmtRps } from '../utils';

interface Props {
  servers: ServerData[];
  tests: string[];
  run: string;
}

const { servers, tests, run } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

type PreflightStatus = 'pass' | 'fail' | 'skip';

function weightedErrorRate(server: ServerData): number {
  let totalRps = 0, totalFail = 0;
  for (const t of tests) {
    const vusData = server.benchmark[t];
    if (!vusData) continue;
    const maxVus = Math.max(...Object.keys(vusData).map(Number));
    const pt = vusData[maxVus];
    if (!pt) continue;
    totalRps  += pt.rps;
    totalFail += pt.rps * pt.errorRate;
  }
  return totalRps > 0 ? totalFail / totalRps : 0;
}


const rows = servers.map((s, i) => ({
  rank: i + 1,
  id: s.id,
  score: s.score,
  rawScore: s.rawScore,
  errRate: weightedErrorRate(s),
  preflight: s.preflight,
}));
---

<div class="wrap">
  <table>
    <thead>
      <tr>
        <th class="col-rank">#</th>
        <th class="col-server">Server</th>
        <th class="col-num r"></th>
        <th class="col-score">Score</th>
        <th class="col-num r">Errors</th>
        <th class="col-tests">Tests</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr>
          <td class="rank">{row.rank}</td>
          <td class="server"><a class="server-link" href={`${base}/results/${run}/servers/${row.id}`}>{row.id}</a></td>
          <td class="num r">{fmtRps(row.rawScore)}</td>
          <td class="score-cell">
            <div class="bar-wrap">
              <div class="bar-track">
                <div class="bar-fill" style={`width:${row.score.toFixed(1)}%;--s:${row.score.toFixed(1)};animation-delay:${i * 60}ms`}></div>
              </div>
              <span class="bar-pct">{Math.round(row.score)}%</span>
            </div>
          </td>
          <td class:list={['num', 'r', row.errRate >= 0.01 ? 'err-bad' : row.errRate >= 0.0001 ? 'err-warn' : 'err-ok']}>
            {(row.errRate * 100).toFixed(2)}%
          </td>
          <td class="tests-cell">
            <div class="pips">
              {tests.map(test => {
                const status = (row.preflight[test] ?? 'skip') as PreflightStatus;
                return <span class={`pip pip-${status}`} title={`${test}: ${status}`}></span>;
              })}
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-base);
    white-space: nowrap;
  }

  thead th {
    text-align: left;
    padding: 10px 16px;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  thead th.r { text-align: right; }

  tbody tr { border-bottom: 1px solid var(--border); }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: rgba(255, 255, 255, 0.03); }

  td { padding: 12px 16px; vertical-align: middle; }
  td.r { text-align: right; }

  .rank     { color: var(--text-muted); font-size: var(--text-sm); width: 48px; }
  .col-server { width: 140px; }
  .col-num    { width: 80px; }
  .col-score  { width: 100%; }
  .col-tests  { width: 1px; white-space: nowrap; }
  .server { font-weight: 500; color: #e4e4e4; }
  .server-link {
    color: inherit;
    text-decoration: underline dotted;
    text-decoration-color: rgba(255, 255, 255, 0.2);
    text-underline-offset: 3px;
  }
  .server-link:hover { color: var(--text); }

  .num {
    font-variant-numeric: tabular-nums;
    color: var(--text-dim);
  }

  .err-bad  { color: #c07030; }
  .err-warn { color: #8a7a30; }
  .err-ok   { color: var(--text-muted); }

  /* Score bar */
  .score-cell { min-width: 220px; width: 100%; }
  .bar-wrap { display: flex; align-items: center; gap: 8px; }
  .bar-track {
    flex: 1;
    height: 26px;
    border-radius: var(--radius-sm);
    min-width: 140px;
    background: var(--surface-2);
  }
  .bar-fill {
    height: 100%;
    border-radius: var(--radius-sm);
    background: linear-gradient(90deg, #f2495c 0%, #fade2a 50%, #73bf69 100%);
    /* Scale gradient so it always spans the full reference width */
    background-size: calc(100% * 100 / var(--s)) 100%;
    transform-origin: left center;
    animation: bar-grow 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  @keyframes bar-grow {
    from { transform: scaleX(0); }
  }
  .bar-pct {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    font-size: var(--text-base);
    min-width: 40px;
    text-align: right;
    color: var(--text-dim);
  }

  /* Preflight pips */
  .pips { display: flex; gap: 2px; align-items: center; }
  .pip {
    width: 7px;
    height: 7px;
    border-radius: 1px;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .pip-pass { background: var(--pass); opacity: 0.45; }
  .pip-fail { background: var(--fail); opacity: 0.5; }
  .pip-skip { background: var(--skip); opacity: 0.2; }

  /* Brighten pips on row hover */
  tbody tr:hover .pip-pass { opacity: 1; }
  tbody tr:hover .pip-fail { opacity: 1; }
  tbody tr:hover .pip-skip { opacity: 0.35; }
</style>
